# Please do not use this ignore file to define platform specific files.
#
# For these purposes create a global .gitignore file, which is a list of rules
# for ignoring files in every Git repository on your workstation.
#
# https://help.github.com/articles/ignoring-files/#create-a-global-gitignore

# Do not ignore .vscode directory.
!/.vscode

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# Application environment variables.
/.env
/.env.*

# Build output
/sortie
/sortie.exe

.sortie.db
.sortie.db-shm
.sortie.db-wal

# Ignore generated plans, specs and review files.
/.plans
/.reviews
/.specs
/.tasks

# Sortie user documentation and blog posts
/website
/blog
