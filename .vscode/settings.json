{
  // ── File Associations ───────────────────────────────────────────────────────
  "files.associations": {
    "**/CODEOWNERS": "plaintext"
  },

  // ── Agent Configuration ────────────────────────────────────────────────────
  // Enable the use of AGENTS.md file for agent configuration including nested agents.
  // See: https://agents.md
  "chat.useAgentsMdFile": true,
  "chat.useClaudeMdFile": false,

  // Note: As of 13 January 2026 this feature is in Experimental stage.
  "chat.useNestedAgentsMdFiles": true,

  // Increase the maximum number of requests an agent can make in a single session.
  // Default is usually 25.
  "chat.agent.maxRequests": 99,

  // ── Agent Skills ───────────────────────────────────────────────────────────
  // Enable the use of agent skills: https://agentskills.io
  // Note: As of 13 January 2026 this feature is in Experimental stage.
  "chat.useAgentSkills": true,
  "chat.experimental.useSkillAdherencePrompt": true,

  "chat.agentSkillsLocations": {
    ".claude/skills": false,
    "~/.claude/skills": false,
    ".github/skills": true,
    ".agents/skills": false,
    "~/.copilot/skills": true,
    "~/.agents/skills": false
  },

  // ── Agent File Locations ───────────────────────────────────────────────────
  "chat.instructionsFilesLocations": {
    "~/.claude/rules": false,
    ".claude/rules": false,
    ".github/instructions": true,
    "~/.copilot/instructions": true
  },

  "chat.hookFilesLocations": {
    "~/.claude/settings.json": false,
    ".claude/settings.json": false,
    ".claude/settings.local.json": false,
    ".github/hooks": true,
    "~/.copilot/hooks": true
  },

  "chat.agentFilesLocations": {
    ".claude/agents": false,
    "~/.claude/agents": false,
    ".github/agents": true,
    "~/.copilot/agents": true
  },

  // ── Agent Terminal ─────────────────────────────────────────────────────────
  // Setting PAGER to "cat" to avoid interactive pager blocking output in terminal
  // when agent runs commands like `gh pr view`.
  "chat.tools.terminal.terminalProfile.linux": {
    "path": "/bin/bash",
    "args": ["-l"],
    "env": {
      "GH_PAGER": "cat",
      "GIT_PAGER": "cat",
      "MANPAGER": "cat",
      "PAGER": "cat"
    }
  },

  // ── Copilot Instructions ───────────────────────────────────────────────────
  // Use instruction files for code generation requests.
  // See: https://code.visualstudio.com/docs/copilot/customization/custom-instructions
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,

  // Custom instruction files for code review for the current selection.
  // See: https://code.visualstudio.com/docs/copilot/customization/custom-instructions
  // Note: As of 13 January 2026 this feature is in Preview stage.
  "github.copilot.chat.reviewSelection.instructions": [
    { "file": ".github/instructions/code-review.instructions.md" }
  ],

  // Custom instruction files for commit message generation.
  // See: https://code.visualstudio.com/docs/copilot/customization/custom-instructions
  // Note: As of 13 January 2026 this feature is in Experimental stage.
  "github.copilot.chat.commitMessageGeneration.instructions": [
    { "file": ".github/instructions/commit-messages.instructions.md" }
  ],

  // Custom instruction files for pull request description generation.
  // See: https://code.visualstudio.com/docs/copilot/customization/custom-instructions
  // Note: As of 13 January 2026 this feature is in Experimental stage.
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    { "file": ".github/skills/creating-pr/SKILL.md" }
  ],

  // ── Copilot Suggestions ────────────────────────────────────────────────────
  // Enable or disable inline suggestions for specified languages.
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },

  // Enables next edit suggestions.
  // See: https://code.visualstudio.com/docs/copilot/ai-powered-suggestions#_next-edit-suggestions
  "github.copilot.nextEditSuggestions.enabled": true,

  // ── Copilot Debug Logging ──────────────────────────────────────────────────
  // Enable detailed logging for agent execution to help with debugging and development.
  // See: https://code.visualstudio.com/docs/copilot/chat/chat-debug-view
  "github.copilot.chat.agentDebugLog.enabled": true,
  "github.copilot.chat.agentDebugLog.fileLogging.enabled": true,

  // ── Search ─────────────────────────────────────────────────────────────────
  // Let Copilot guess what you are looking for in search.
  // This will enable semantic search when appropriate.
  // Note: As of 13 January 2026 this feature is in Preview stage.
  "search.searchView.semanticSearchBehavior": "auto",

  // ── Editor ─────────────────────────────────────────────────────────────────
  // Set a ruler at 100 characters to help maintain line length.
  "editor.rulers": [100, 120],

  // ── Testing ────────────────────────────────────────────────────────────────
  // Show pass/fail count badge on the Testing icon in the Activity Bar.
  "testing.countBadge": "failed",

  // Show inline test controls in the editor gutter.
  "testing.gutterEnabled": true,

  // Clicking the gutter icon runs the test (not debug).
  "testing.defaultGutterClickAction": "run",

  // Coverage bar thresholds: red < 50%, yellow 50-80%, green > 80%.
  "testing.coverageBarThresholds": {
    "red": 0,
    "yellow": 50,
    "green": 80
  },

  // Show the minimum coverage percentage (statement vs branch) in Test Coverage view.
  "testing.displayedCoveragePercent": "minimum",

  // Show coverage percentage inline in the Explorer file tree.
  "testing.showCoverageInExplorer": true,

  // ── Go Test Settings ───────────────────────────────────────────────────────
  // Always run tests with -race and -count=1 to match the Makefile.
  "go.testFlags": ["-race", "-count=1"],

  // Generous timeout for integration tests.
  "go.testTimeout": "120s",

  // Show test coverage in the gutter after running package tests.
  "go.coverOnTestPackage": true,

  // Use atomic coverage mode (required when -race is enabled).
  "go.coverMode": "atomic",

  // ── Go-specific Settings ───────────────────────────────────────────────────────
  "go.goroot": "~/.asdf/installs/golang/1.26.1/go",
  "go.gopath": "~/.asdf/installs/golang/1.26.1/packages",
  "go.alternateTools": {
    "go": "~/.asdf/shims/go"
  },
  "go.toolsEnvVars": {
    "GOBIN": "~/.local/bin",
    "GOPATH": "~/.asdf/installs/golang/1.26.1/packages",
    "GOROOT": "~/.asdf/installs/golang/1.26.1/go"
  }
}
