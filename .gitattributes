# Normalize line endings - Go tooling expects LF
* text=auto eol=lf

# Shows function names in hunk headers
*.go diff=golang

# Collapsed in GitHub PR diffs, excluded from language stats
go.sum linguist-generated

# Excluded from GitHub language stats
docs/** linguist-documentation
examples/** linguist-documentation

# Set the language for VS Config files to JSONC
# to ensure GitHub doesn't show the comments as errors.
.vscode/*.json diff=json linguist-language=JSONC
